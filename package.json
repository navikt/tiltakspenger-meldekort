{
    "name": "tiltakspenger-meldekort",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "prepare": "husky",
        "dev": "npm run dev --workspace server",
        "start": "npm run start --workspace server",
        "build": "npm-run-all build:*",
        "build:client": "vite build --outDir server/dist/client",
        "build:ssr": "vite build --ssr src/main-server.tsx --outDir server/src/_ssr-dist --emptyOutDir false",
        "build:server": "npm run build --workspace server",
        "lint": "npm-run-all --parallel lint:*",
        "lint:tsc": "tsc --noEmit",
        "lint:tsc-server": "npm run tsc --workspace server",
        "lint:eslint": "eslint \"**/*.ts\" \"**/*.tsx\"",
        "test": "playwright test",
        "test:ui": "playwright test --ui"
    },
    "workspaces": [
        "server"
    ],
    "dependencies": {
        "@navikt/aksel-icons": "8.9.0",
        "@navikt/ds-css": "8.9.0",
        "@navikt/ds-react": "8.9.0",
        "@navikt/nav-dekoratoren-moduler": "3.7.0",
        "@preact/compat": "18.3.2",
        "dayjs": "1.11.20",
        "date-easter": "1.0.3",
        "preact-render-to-string": "6.6.7",
        "swr": "2.4.1",
        "wouter": "3.9.0"
    },
    "devDependencies": {
        "@axe-core/playwright": "4.11.0",
        "@eslint/js": "10.0.1",
        "@playwright/test": "1.58.2",
        "@preact/preset-vite": "2.10.5",
        "@types/node": "24.12.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/eslint-plugin": "8.57.2",
        "@typescript-eslint/parser": "8.57.2",
        "@vitejs/plugin-react": "5.2.0",
        "eslint": "9.39.4",
        "eslint-plugin-css-modules": "2.12.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-react-refresh": "0.5.2",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "npm-run-all": "4.1.5",
        "playwright": "1.58.2",
        "prettier": "3.8.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "rollup-plugin-visualizer": "6.0.11",
        "typescript": "5.9.3",
        "vite": "7.3.1",
        "vite-tsconfig-paths": "6.1.1"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint"
        ],
        "*.{ts,tsx,css}": [
            "prettier --write"
        ]
    }
}
