{
    "name": "tiltakspenger-meldekort",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "packageManager": "pnpm@11.1.2",
    "scripts": {
        "prepare": "husky",
        "dev": "pnpm --filter @meldekort/server dev",
        "start": "pnpm --filter @meldekort/server deploy-and-start",
        "build": "pnpm --filter @meldekort/client build && pnpm --filter @meldekort/server build",
        "lint": "pnpm run /^lint:/",
        "lint:tsc-client": "pnpm --filter @meldekort/client tsc",
        "lint:tsc-server": "pnpm --filter @meldekort/server tsc",
        "lint:eslint": "eslint \"**/*.ts\" \"**/*.tsx\"",
        "test": "playwright test",
        "test:ui": "playwright test --ui"
    },
    "comments": "Husk å holde imaget i GHA workflow i sync med playwright-versjonen i devDependencies",
    "devDependencies": {
        "@axe-core/playwright": "4.11.3",
        "@eslint/js": "9.39.4",
        "@playwright/test": "1.59.1",
        "@types/node": "24.12.2",
        "@typescript-eslint/eslint-plugin": "8.59.2",
        "@typescript-eslint/parser": "8.59.2",
        "dotenv": "17.4.2",
        "eslint": "9.39.4",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-css-modules": "2.12.0",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-react-refresh": "0.5.2",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "playwright": "1.59.1",
        "prettier": "3.8.3",
        "typescript": "5.9.3"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint"
        ],
        "*.{ts,tsx,css}": [
            "prettier --write"
        ]
    }
}
