{
    "name": "tiltakspenger-meldekort",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "packageManager": "pnpm@11.1.1",
    "scripts": {
        "prepare": "husky",
        "dev": "pnpm --filter tiltakspenger-meldekort-server dev",
        "start": "pnpm --filter tiltakspenger-meldekort-server deploy-and-start",
        "build": "pnpm run build:client && pnpm run build:ssr && pnpm run build:server",
        "build:client": "vite build --outDir server/dist/client",
        "build:ssr": "vite build --ssr src/main-server.tsx --outDir server/src/_ssr-dist --emptyOutDir false",
        "build:server": "pnpm --filter tiltakspenger-meldekort-server build",
        "lint": "pnpm run /^lint:/",
        "lint:tsc": "tsc --noEmit",
        "lint:tsc-server": "pnpm --filter tiltakspenger-meldekort-server tsc",
        "lint:eslint": "eslint \"**/*.ts\" \"**/*.tsx\"",
        "test": "playwright test",
        "test:ui": "playwright test --ui"
    },
    "dependencies": {
        "@navikt/aksel-icons": "8.10.4",
        "@navikt/ds-css": "8.10.4",
        "@navikt/ds-react": "8.10.4",
        "@navikt/nav-dekoratoren-moduler": "3.7.1",
        "@preact/compat": "18.3.2",
        "dayjs": "1.11.20",
        "dotenv": "17.4.2",
        "preact": "10.29.1",
        "preact-render-to-string": "6.6.7",
        "swr": "2.4.1",
        "wouter": "3.9.0"
    },
    "comments": "Husk å holde imaget i GHA workflow i sync med playwright-versjonen i devDependencies",
    "devDependencies": {
        "@axe-core/playwright": "4.11.3",
        "@eslint/js": "9.39.4",
        "@playwright/test": "1.59.1",
        "@preact/preset-vite": "2.10.5",
        "@types/node": "24.12.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/eslint-plugin": "8.59.2",
        "@typescript-eslint/parser": "8.59.2",
        "@vitejs/plugin-react": "5.2.0",
        "eslint": "9.39.4",
        "eslint-plugin-css-modules": "2.12.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-react-refresh": "0.5.2",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "lodash": "4.18.1",
        "playwright": "1.59.1",
        "prettier": "3.8.3",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "rollup-plugin-visualizer": "6.0.11",
        "typescript": "5.9.3",
        "vite": "7.3.3",
        "vite-tsconfig-paths": "6.1.1"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint"
        ],
        "*.{ts,tsx,css}": [
            "prettier --write"
        ]
    }
}
