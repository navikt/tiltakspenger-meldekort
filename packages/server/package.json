{
    "name": "@meldekort/server",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "node build.mjs",
        "build-and-watch": "node build.mjs watch",
        "start": "node -r dotenv/config ./dist/server.cjs dotenv_config_path=../.env",
        "deploy-and-start": "cd ../.. && pnpm deploy --filter @meldekort/server --prod --force deploy && cp -r packages/server/dist deploy/dist && cd deploy && pnpm start",
        "nodemon-start": "nodemon -r dotenv/config -w ./dist/server.cjs -w ../../.env.development ./dist/server.cjs dotenv_config_path=../../.env.development",
        "dev": "concurrently -n esbuild,nodemon -c blue,green -k \"pnpm run build-and-watch\" \"pnpm run nodemon-start\"",
        "tsc": "tsc --noEmit"
    },
    "dependencies": {
        "@meldekort/common": "workspace:*",
        "@navikt/nav-dekoratoren-moduler": "4.0.0",
        "@navikt/oasis": "4.1.4",
        "compression": "1.8.1",
        "csp-header": "6.3.1",
        "dayjs": "1.11.20",
        "dotenv": "17.4.2",
        "express": "5.2.1",
        "http-terminator": "3.2.0",
        "sirv": "3.0.2"
    },
    "devDependencies": {
        "@types/compression": "1.8.1",
        "@types/express": "5.0.6",
        "concurrently": "9.2.1",
        "esbuild": "0.28.0",
        "nodemon": "3.1.14",
        "vite": "7.3.3"
    },
    "nodemonConfig": {
        "delay": 500
    }
}
